{
  "name": "@opensprint/electron",
  "productName": "Open Sprint",
  "version": "0.3.0",
  "private": true,
  "description": "Desktop packaging workspace for Open Sprint",
  "author": "Open Sprint Team",
  "main": "dist/main.js",
  "scripts": {
    "compile": "tsc",
    "prepare:resources": "node scripts/prepare-desktop-resources.js",
    "prepare:resources:win:x64": "node scripts/prepare-desktop-resources.js --platform win32 --arch x64",
    "prepare:resources:win:arm64": "node scripts/prepare-desktop-resources.js --platform win32 --arch arm64",
    "prepare:resources:mac:x64": "node scripts/prepare-desktop-resources.js --platform darwin --arch x64",
    "prepare:resources:mac:arm64": "node scripts/prepare-desktop-resources.js --platform darwin --arch arm64",
    "prepare:resources:linux:x64": "node scripts/prepare-desktop-resources.js --platform linux --arch x64",
    "prepare:resources:linux:arm64": "node scripts/prepare-desktop-resources.js --platform linux --arch arm64",
    "start": "npm run compile && electron .",
    "build": "node scripts/build-target.js",
    "build:dir": "node scripts/build-target.js --dir",
    "build:mac": "node scripts/build-target.js --platform darwin",
    "build:mac:x64": "node scripts/build-target.js --platform darwin --arch x64",
    "build:mac:arm64": "node scripts/build-target.js --platform darwin --arch arm64",
    "build:win": "npm run build:win:x64",
    "build:win:x64": "node scripts/build-target.js --platform win32 --arch x64",
    "build:win:arm64": "node scripts/build-target.js --platform win32 --arch arm64",
    "build:linux": "node scripts/build-target.js --platform linux",
    "build:linux:x64": "node scripts/build-target.js --platform linux --arch x64",
    "build:linux:arm64": "node scripts/build-target.js --platform linux --arch arm64",
    "test": "npx vitest run"
  },
  "dependencies": {},
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "vitest": "^2.1.0",
    "electron": "41.0.2",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.25.12",
    "sharp": "^0.33.5",
    "typescript": "^5.7.2"
  },
  "build": {
    "appId": "com.opensprint.app",
    "productName": "Open Sprint",
    "electronVersion": "41.0.2",
    "afterSign": "./scripts/after-sign-notarize.js",
    "compression": "maximum",
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist/main.js",
      "dist/preload.js",
      "dist/boot-screen.js",
      "dist/window-options.js"
    ],
    "extraResources": [
      {
        "from": "desktop-resources/backend",
        "to": "backend"
      },
      {
        "from": "desktop-resources/frontend",
        "to": "frontend"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "hardenedRuntime": true,
      "notarize": false,
      "target": [
        "dmg"
      ],
      "artifactName": "Open.Sprint-${arch}.${ext}",
      "icon": "../frontend/public/desktop-icon-mac.png"
    },
    "dmg": {
      "sign": false
    },
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "Open.Sprint-${arch}.${ext}",
      "icon": "../frontend/public/logo-512x512.png"
    },
    "nsis": {
      "oneClick": false,
      "deleteAppDataOnUninstall": false
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "artifactName": "Open.Sprint-${arch}.${ext}",
      "icon": "../frontend/public/logo-512x512.png"
    }
  }
}
