{
  "name": "@opensprint/backend",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "cross-env OPENSPRINT_PRESERVE_AGENTS=1 tsx watch --ignore 'data/**' --ignore '**/*.jsonl' --ignore '../shared/dist/**' src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "reset-in-progress-tasks": "tsx src/scripts/reset-in-progress-tasks.ts",
    "test": "node ../../node_modules/vitest/vitest.mjs run",
    "test:coverage": "node ../../node_modules/vitest/vitest.mjs run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@google/genai": "^1.43.0",
    "@opensprint/shared": "*",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.5",
    "diff": "^8.0.3",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.38.0",
    "express": "^4.21.0",
    "mammoth": "^1.11.0",
    "multer": "^2.0.2",
    "openai": "^6.25.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.13.0",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.11.0",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.5.0",
    "cross-env": "^10.1.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
