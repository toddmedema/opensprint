{
  "name": "opensprint",
  "version": "0.3.0",
  "private": true,
  "description": "AI-powered software development lifecycle platform",
  "workspaces": [
    "packages/shared",
    "packages/backend",
    "packages/frontend",
    "packages/electron"
  ],
  "scripts": {
    "dev": "rm -rf packages/shared/dist && bash scripts/ensure-postgres-running.sh && concurrently \"npm run dev -w packages/shared\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm run dev -w packages/backend",
    "dev:frontend": "npm run dev -w packages/frontend",
    "build": "npm run build -w packages/shared && npm run build -w packages/backend && npm run build -w packages/frontend",
    "build:shared": "npm run build -w packages/shared",
    "build:backend": "npm run build -w packages/backend",
    "build:frontend": "npm run build -w packages/frontend",
    "test": "npm run test --workspaces --if-present",
    "verify:source": "bash scripts/verify-source-imports.sh",
    "verify:desktop-artifacts": "node scripts/verify-desktop-artifact-names.js",
    "branch-protection:apply": "bash scripts/apply-branch-protection.sh",
    "lint": "npm run lint --workspaces --if-present -- --max-warnings=0",
    "lint:ci": "npm run lint && npm run format:check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "clean": "npm run clean --workspaces --if-present && rm -rf node_modules",
    "setup": "bash scripts/setup.sh",
    "perf": "npx tsx scripts/perf.ts",
    "perf:baseline": "npx tsx scripts/perf.ts --baseline",
    "perf:compare": "npx tsx scripts/perf.ts --compare",
    "delete-hil-notifications": "npx tsx scripts/delete-hil-notifications.ts",
    "migrate:opensprint": "npx tsx scripts/migrate-opensprint-to-db.ts",
    "build:desktop": "npm run build && node packages/electron/scripts/prepare-desktop-resources.js && npm run build -w packages/electron",
    "build:desktop:win": "npm run build && npm run build:win -w packages/electron",
    "build:desktop:win:arm64": "npm run build && npm run build:win:arm64 -w packages/electron",
    "start:desktop": "bash scripts/check-linux-desktop-prereqs.sh && npm run build && node packages/electron/scripts/prepare-desktop-resources.js && npm run start -w packages/electron"
  },
  "engines": {
    "node": "24.x"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript-eslint": "^8.18.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "puppeteer": "^24.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md}": [
      "prettier --write"
    ],
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix"
    ]
  }
}
